# ─────────────────────────────────────────────────────────────────────────────
# CadeiraPro — environment variables (template)
#
# Real staging values live OUTSIDE this repo at:
#   C:\Users\gdepa\Desktop\cadeirapro-secrets\env.staging.txt
# Never copy real values into this file. Never commit a real .env.
#
# This template lists every variable from Build Guide §12.2 with placeholders.
# Variables marked "S3+" / "S4+" land in later sprints; left in template so
# CI / config validators have the canonical list from day one.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
LOG_LEVEL=debug
IDEMPOTENCY_TTL_HOURS=24

# Public URLs (Workers + Pages staging)
API_BASE_URL=https://cadeirapro-api.example.workers.dev
DASHBOARD_BASE_URL=https://cadeirapro-dashboard.pages.dev
WIDGET_BASE_URL=https://widget.example.pages.dev

# Supabase (S1)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role...
SUPABASE_DB_PASSWORD=replace-me

# Platform Pix — used at sign-up to seed organizations.platform_fee_pct (S1)
# and as the platform recipient in three-way splits (S3).
PLATFORM_PIX_KEY=00.000.000/0001-00
PLATFORM_PIX_KEY_TYPE=cnpj
PLATFORM_FEE_DEFAULT_PCT=0.005

# Transfeera (S3+)
TRANSFEERA_API_BASE=https://api.transfeera.com
TRANSFEERA_API_KEY=replace-me
TRANSFEERA_WEBHOOK_SECRET=replace-me

# WhatsApp Cloud API (S4+)
WHATSAPP_APP_ID=replace-me
WHATSAPP_APP_SECRET=replace-me
WHATSAPP_VERIFY_TOKEN=replace-me

# Email — Supabase built-in SMTP for S1; Resend lands when transactional
# templates need branding.
RESEND_API_KEY=

# Observability (S1 partial; Sentry provisioned later in S1)
SENTRY_DSN=

# Frontend (Cloudflare Pages env vars — set in dashboard, not committed)
VITE_API_BASE=https://cadeirapro-api.example.workers.dev
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxx
VITE_SENTRY_DSN=
